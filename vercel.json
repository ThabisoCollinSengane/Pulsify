{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/business",       "destination": "/apps/business/index.html" },
    { "source": "/business/(.*)",  "destination": "/apps/business/$1" },
    { "source": "/organizer",      "destination": "/apps/organizer/index.html" },
    { "source": "/organizer/(.*)", "destination": "/apps/organizer/$1" },
    { "source": "/leads",          "destination": "/apps/leads/index.html" },
    { "source": "/leads/(.*)",     "destination": "/apps/leads/$1" },
    { "source": "/admin",          "destination": "/apps/admin/index.html" },
    { "source": "/admin/(.*)",     "destination": "/apps/admin/$1" },
    { "source": "/",               "destination": "/apps/landing-page/index.html" },
    { "source": "/(.+)",           "destination": "/apps/landing-page/$1" }
  ]
}

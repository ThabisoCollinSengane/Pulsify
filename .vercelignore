# Guard: never deploy a root index.html — it shadows the /(.*) rewrite that
# serves apps/landing-page/index.html for "/". (See CLAUDE.md deployment gotcha.)
/index.html

# Backup files (future-proof guards — backups should never reach production)
*.bak
*.bak.*
*.backup
*.backup.*

# Dev-only folders not needed for deployment
_archive/
db/
docs/
scripts/
supabase/
.claude/
.idx/
